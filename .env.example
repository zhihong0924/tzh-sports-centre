# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Full URL of the app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Used for receipt screenshots and profile avatars
BLOB_READ_WRITE_TOKEN=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Used for shop checkout only
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Shared secret to authenticate Vercel cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Nodemailer SMTP — for booking/lesson notifications
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── AI (optional) ────────────────────────────────────────────────────────────
# Google Gemini — used for the chat assistant feature
GOOGLE_GENERATIVE_AI_API_KEY=""
